# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com > API Keys)
RESEND_API_KEY=
# Must be an email on a domain you verified in Resend
INVOICE_FROM_EMAIL=invoices@yourdomain.com

# Your info
COMPANY_NAME=Star Link Freight Inc.
# Where reminder summaries and "invoices" replies go
OWNER_EMAIL=you@example.com

# Random long string you make up — protects the /api/cron/reminders endpoint
CRON_SECRET=
